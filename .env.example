# remlab env. Копия -> .env на сервере (/opt/remlab/.env). НЕ коммитить .env.
# Секреты не хранятся в git и в Memory Bank.

# Версия сборки (подставляется deploy.sh)
APP_VERSION=dev

# Postgres (контейнер remlab-db)
POSTGRES_PASSWORD=change-me-strong-password
# DATABASE_URL собирается в compose из POSTGRES_PASSWORD:
#   postgres://remlab:${POSTGRES_PASSWORD}@db:5432/remlab

# --- Ниже появится по мере фич (Stage 1+), пока не обязательно ---
# Инференс
# FAL_KEY=
# REPLICATE_API_TOKEN=
# GOOGLE_VERTEX_PROJECT=
# GOOGLE_VERTEX_LOCATION=
# Платежи
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=
# Observability
# SENTRY_DSN=
# POSTHOG_KEY=
# Inngest
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
