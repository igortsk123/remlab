# remlab env. Копия -> .env на сервере (/opt/remlab/.env). НЕ коммитить .env.
# Секреты не хранятся в git и в Memory Bank.

# Версия сборки (подставляется deploy.sh)
APP_VERSION=dev

# Postgres (контейнер remlab-db)
POSTGRES_PASSWORD=change-me-strong-password
# DATABASE_URL собирается в compose из POSTGRES_PASSWORD:
#   postgres://remlab:${POSTGRES_PASSWORD}@db:5432/remlab

# --- Инференс ИИ (Stage 1: M0) ---
# Google Gemini — текст+зрение (анализ фото) и генерация картинок (Nano Banana 2).
GEMINI_API_KEY=
# OpenAI — опционально (провайдер сменный); пока не используется.
# OPENAI_API_KEY=
# Прочие провайдеры (запас):
# FAL_KEY=
# REPLICATE_API_TOKEN=
# GOOGLE_VERTEX_PROJECT=
# GOOGLE_VERTEX_LOCATION=
# Платежи
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=
# Observability (бесплатные тарифы; без ключа — выключено, no-op)
# PostHog (аналитика + ошибки): 1M событий/мес бесплатно. EU-хост для RU-данных.
# POSTHOG_KEY=
# POSTHOG_HOST=https://eu.i.posthog.com
# Sentry (отдельно, опц.): 5k ошибок/мес бесплатно. Подключим его SDK при желании.
# SENTRY_DSN=
# Inngest
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# --- Трейсинг AI-пайплайна (ADR-0013) ---
# Картинки-ассеты трейса на томе (в контейнере). Локально дефолт ./.data/traces.
TRACE_DIR=/app/data/traces
# Сжатие картинок сервисом imagor (internal-only на remlab-net). Пусто → шлём фото в LLM как есть.
IMAGOR_BASE_URL=http://remlab-imagor:8000
# Гард admin-роутов разбора (/api/trace/*). Пусто → доступ открыт (только для dev!). В проде задать.
# TRACE_ADMIN_TOKEN=
# Сколько дней хранить трейсы/фото (pnpm trace:prune из таймера remlab-cleanup).
TRACE_RETENTION_DAYS=90
# Оплата YooKassa (К5 — визуализация 60 ₽). Без ключей платные функции деградируют (виз. остаётся бесплатной).
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=
# Публичный URL приложения для return_url оплаты (дефолт — https://remont-lab.online).
# APP_URL=https://remont-lab.online
